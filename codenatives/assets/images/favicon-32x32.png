<script type="text/javascript" id="jquery-js-after">
/* <![CDATA[ */

    jQuery(document).ready(function($) {
        var highest = 0;
        jQuery('.landing-blog-title').each(function() {
            var h = jQuery(this).height();
            if (h > highest) {
                highest = h;
            }
        });
        jQuery('.landing-blog-title').css('height', highest + 'px');
    });
    

    jQuery(document).ready(function($) {
        function equalizeHeight() {
            if (window.innerWidth > 768) {
                var highest = 0;
                // Reset heights before recalculating
                jQuery('.blog-content').css('height', 'auto');
                jQuery('.blog-content').each(function() {
                    var h = jQuery(this).height();
                    if (h > highest) {
                        highest = h;
                    }
                });
                jQuery('.blog-content').css('height', highest + 'px');
            } else {
                // Reset to auto height on smaller screens
                jQuery('.blog-content').css('height', 'auto');
            }
        }
        // Run on document ready
        equalizeHeight();
        // Run on window resize
        $(window).resize(function() {
            equalizeHeight();
        });
    });
    
//# sourceURL=jquery-js-after
/* ]]> */
</script>
